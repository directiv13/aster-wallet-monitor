# Copy to .env and fill in. See README.md for how to obtain each value.
# .env is gitignored and excluded from the Docker image — keep it that way.

# --- Required ---------------------------------------------------------------

# From @BotFather (/newbot). Looks like 123456789:AAE...
TELEGRAM_BOT_TOKEN=

# Channel/group where notifications are posted. Groups and channels are
# NEGATIVE numbers, e.g. -1001234567890. See README "Getting the chat id".
TARGET_CHAT_ID=

# Comma-separated Telegram user IDs allowed to /add and /remove.
# Get yours from @userinfobot. Everyone else is read-only.
ADMIN_USER_IDS=

# --- Optional (defaults shown) ----------------------------------------------

# Seconds between poll cycles. Automatically widened if the watchlist is large
# enough that this pace would risk a rate-limit ban.
POLL_INTERVAL_SECONDS=15

# Balance moves smaller than this are ignored, suppressing funding/fee dust.
BALANCE_CHANGE_EPSILON=0.01

# Aster's public JSON-RPC endpoint. No API key exists or is needed.
RPC_BASE_URL=https://tapi.asterdex.com/info

# Where the SQLite file lives. Under Docker this is forced to /data/tracker.db
# by docker-compose.yml so it lands on the persistent volume.
DB_PATH=tracker.db

# Ceiling on requests/second to Aster, shared by the poller and /list. Aster
# publishes no limit and bans abusive IPs outright (HTTP 418), so this is
# deliberately conservative. Raise it only if you know better.
MAX_REQUESTS_PER_SECOND=2.0

# How far back each cycle re-reads fills, so one landing mid-cycle isn't missed.
# Duplicates are absorbed by the dedupe ledger.
FILL_OVERLAP_SECONDS=120

# HTTP timeout for a single Aster call.
REQUEST_TIMEOUT_SECONDS=15

# How long the whole poller stands down after an HTTP 418 (IP ban).
BAN_COOLDOWN_SECONDS=300

# Timezone. Leave UTC unless you have a reason — the fills window is
# timestamp-sensitive. Under Docker this is passed through from here (or defaults
# to UTC in docker-compose.yml).
TZ=UTC

# Liveness file the poller refreshes at the end of each cycle; the container
# HEALTHCHECK reads it. Under Docker this is forced to /data/heartbeat by
# docker-compose.yml so it lands on the persistent volume.
HEARTBEAT_PATH=heartbeat

# Max heartbeat age (seconds) before the container is marked unhealthy and
# restarted. Unset means max(90, 3 x POLL_INTERVAL_SECONDS). Raise it for large
# watchlists, whose effective interval widens above POLL_INTERVAL_SECONDS.
# HEARTBEAT_MAX_AGE_SECONDS=120
