# Secrets must never reach an image layer — a layer is readable by anyone who
# can pull the image, and deleting the file in a later layer does not remove it.
.env
.env.*
!.env.example

# Local database: shipping it would seed the container with stale state.
*.db
*.db-wal
*.db-shm

.git
.gitignore
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.ruff_cache/
tests/
pytest.ini
requirements-dev.txt
ruff.toml
README.md
CLAUDE.md

# CI/CD and docs are not part of the runtime image.
.github/
scripts/
docs/
*.md
